<Window x:Class="AirPodsController.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="600" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F5F5F7">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Настройки" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="#1C1C1E"/>
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabItem Header="Горячие клавиши">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="ANC:" FontWeight="Bold" Margin="0,5"/>
                        <Border Background="#F2F2F7" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <CheckBox x:Name="ChkANCCtrl" Content="Ctrl" Margin="0,0,15,0"/>
                                    <CheckBox x:Name="ChkANCAlt" Content="Alt" Margin="0,0,15,0"/>
                                    <CheckBox x:Name="ChkANCShift" Content="Shift"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtANC" Text="Не назначено" FontSize="12" Foreground="#8E8E93" HorizontalAlignment="Center"/>
                                <Button Content="Назначить" Height="30" Margin="0,5,0,0" Click="SetANC_Click" Background="#007AFF" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Прозрачность:" FontWeight="Bold" Margin="0,15,0,5"/>
                        <Border Background="#F2F2F7" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <CheckBox x:Name="ChkTransCtrl" Content="Ctrl" Margin="0,0,15,0"/>
                                    <CheckBox x:Name="ChkTransAlt" Content="Alt" Margin="0,0,15,0"/>
                                    <CheckBox x:Name="ChkTransShift" Content="Shift"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtTrans" Text="Не назначено" FontSize="12" Foreground="#8E8E93" HorizontalAlignment="Center"/>
                                <Button Content="Назначить" Height="30" Margin="0,5,0,0" Click="SetTrans_Click" Background="#007AFF" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Заряд:" FontWeight="Bold" Margin="0,15,0,5"/>
                        <Border Background="#F2F2F7" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <CheckBox x:Name="ChkBatCtrl" Content="Ctrl" Margin="0,0,15,0"/>
                                    <CheckBox x:Name="ChkBatAlt" Content="Alt" Margin="0,0,15,0"/>
                                    <CheckBox x:Name="ChkBatShift" Content="Shift"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtBat" Text="Не назначено" FontSize="12" Foreground="#8E8E93" HorizontalAlignment="Center"/>
                                <Button Content="Назначить" Height="30" Margin="0,5,0,0" Click="SetBat_Click" Background="#007AFF" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Уведомления">
                <StackPanel Margin="10">
                    <CheckBox x:Name="ChkNotifyLow" Content="Низкий заряд" Margin="0,5"/>
                    <CheckBox x:Name="ChkNotifyConnect" Content="Подключение" Margin="0,5"/>
                    <CheckBox x:Name="ChkNotifyMode" Content="Смена режима" Margin="0,5"/>
                    <CheckBox x:Name="ChkSound" Content="Звук" Margin="0,5,0,15"/>
                    <TextBlock Text="Порог низкого заряда (%):" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBox x:Name="TxtThreshold" Width="100" HorizontalAlignment="Left" Text="20" Padding="5"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Общие">
                <StackPanel Margin="10">
                    <CheckBox x:Name="ChkAutoStart" Content="Автозапуск" Margin="0,5"/>
                    <CheckBox x:Name="ChkDarkTheme" Content="Тёмная тема" Margin="0,5"/>
                </StackPanel>
            </TabItem>
        </TabControl>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="Сохранить" Width="120" Height="40" Margin="0,0,10,0" Click="Save_Click" Background="#007AFF" Foreground="White" BorderThickness="0"/>
            <Button Content="Отмена" Width="120" Height="40" Click="Cancel_Click" Background="#8E8E93" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>