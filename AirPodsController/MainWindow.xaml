<Window x:Class="AirPodsController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AirPods Controller" 
        Height="820" 
        Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#F2F2F7"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- iOS Menu Bar -->
        <Border Grid.Row="0" Background="White" CornerRadius="0,0,16,16" Padding="10,8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1" Color="#000000"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Click="Settings_Click" Background="Transparent" BorderThickness="0" Margin="5,0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="pack://application:,,,/Resources/icon_settings.png" Width="16" Height="16" Margin="0,0,5,0"/>
                        <TextBlock Text="Настройки" FontSize="13" VerticalAlignment="Center" Foreground="#007AFF"/>
                    </StackPanel>
                </Button>

                <Button Click="Notifications_Click" Background="Transparent" BorderThickness="0" Margin="5,0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="pack://application:,,,/Resources/icon_notifications.png" Width="16" Height="16" Margin="0,0,5,0"/>
                        <TextBlock Text="Уведомления" FontSize="13" VerticalAlignment="Center" Foreground="#007AFF"/>
                    </StackPanel>
                </Button>

                <Button Click="About_Click" Background="Transparent" BorderThickness="0" Margin="5,0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="pack://application:,,,/Resources/icon_about.png" Width="16" Height="16" Margin="0,0,5,0"/>
                        <TextBlock Text="О программе" FontSize="13" VerticalAlignment="Center" Foreground="#007AFF"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="15">
            <StackPanel>
                <!-- Logo -->
                <Image x:Name="LogoImage" Width="110" Height="110" Stretch="Uniform" RenderTransformOrigin="1,1"/>
                <TextBlock Text="AirPods Controller" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" 
                           Foreground="#1C1C1E" Margin="0,0,0,20"/>

                <!-- Device Info Card -->
                <Border Background="White" CornerRadius="14" Padding="15" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Source="pack://application:,,,/Resources/icon_settings.png" Width="22" Height="22"/>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Имя" FontSize="12" Foreground="#8E8E93"/>
                            <TextBlock x:Name="DeviceNameText" Text="Загрузка..." FontSize="14" 
                                       FontWeight="SemiBold" Foreground="#1C1C1E" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Noise Control -->
                <TextBlock Text="УПРАВЛЕНИЕ ШУМОМ" FontSize="11" FontWeight="SemiBold" 
                           Foreground="#8E8E93" Margin="0,0,0,10"/>

                <Border Background="White" CornerRadius="14" Padding="5" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Анимированный синий фон -->
                        <Border x:Name="HighlightBorder" 
                                Background="#007AFF" 
                                CornerRadius="10" 
                                Margin="3"
                                Grid.Column="0">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="HighlightTransform" X="0"/>
                            </Border.RenderTransform>
                        </Border>

                        <Button Grid.Column="0" x:Name="OffButton" Height="56" Margin="3" 
                                Click="Off_Click" Background="Transparent" BorderThickness="0">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/Resources/icon_off.png" Width="24" Height="24" Stretch="Uniform"/>
                                <TextBlock x:Name="OffText" Text="Выкл" FontSize="11" FontWeight="SemiBold" 
                        Margin="0,3,0,0" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1" x:Name="AncButton" Height="56" Margin="3" 
                                Click="ANC_Click" Background="Transparent" BorderThickness="0">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/Resources/icon_anc.png" Width="24" Height="24" Stretch="Uniform"/>
                                <TextBlock x:Name="AncText" Text="ANC" FontSize="11" FontWeight="SemiBold" 
                                           Margin="0,3,0,0" Foreground="#1C1C1E"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2" x:Name="TransButton" Height="56" Margin="3" 
                                Click="Transparency_Click" Background="Transparent" BorderThickness="0">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/Resources/icon_transparency.png" Width="24" Height="24" Stretch="Uniform"/>
                                <TextBlock x:Name="TransText" Text="Прозрачность" FontSize="11" FontWeight="SemiBold" 
                                           Margin="0,3,0,0" Foreground="#1C1C1E"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="3" x:Name="AdaptiveButton" Height="56" Margin="3" 
                                Click="Adaptive_Click" Background="Transparent" BorderThickness="0">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/Resources/icon_adaptive.png" Width="24" Height="24" Stretch="Uniform" Opacity="0.6"/>
                                <TextBlock x:Name="AdaptiveText" Text="Адаптивное" FontSize="11" FontWeight="SemiBold" 
                                           Margin="0,3,0,0" Foreground="#1C1C1E"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Devices Card -->
                <TextBlock Text="УСТРОЙСТВА" FontSize="11" FontWeight="SemiBold" 
                           Foreground="#8E8E93" Margin="0,0,0,10"/>

                <Border Background="White" CornerRadius="14" Padding="20" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <Image x:Name="EarbudsImage" Width="90" Height="60"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LeftBatteryText" Text="--%" FontSize="18" FontWeight="Bold" 
                                           Foreground="#8E8E93" Grid.Column="0" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="RightBatteryText" Text="--%" FontSize="18" FontWeight="Bold" 
                                           Foreground="#8E8E93" Grid.Column="1" HorizontalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Л / П" FontSize="11" Foreground="#8E8E93" 
                                       HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <Image x:Name="CaseImage" Width="70" Height="60"/>
                            <TextBlock x:Name="CaseBatteryText" Text="--%" FontSize="18" FontWeight="Bold" 
                                       Foreground="#8E8E93" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="Кейс" FontSize="11" Foreground="#8E8E93" 
                                       HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Battery Refresh Button -->
                <Button x:Name="BtnRefreshBattery" Height="45" Margin="0,0,0,12" Click="CheckBattery_Click" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border Background="#5856D6" CornerRadius="14">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="Обновить заряд" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                </Button>

                <!-- Connect Button -->
                <Button x:Name="BtnConnect" Height="50" Margin="0,0,0,12" Click="Connect_Click" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border Background="#34C759" CornerRadius="14">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="Подключиться" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                </Button>

                <!-- Status -->
                <TextBlock x:Name="StatusText" Text="Нажмите «Подключиться»" FontSize="13" 
                           Foreground="#8E8E93" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>